# Copy to infra/.env and fill before prod compose.
# Never commit the real .env file.
#
#   cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=chid_mortgage
POSTGRES_USER=chid
POSTGRES_PASSWORD=change-me-strong-db-password

# --- Backend ---
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRATION_MS=1296000000
CORS_ALLOWED_ORIGINS=https://chid.ru,https://www.chid.ru,https://crm.chid.ru

# First admin (created once on empty DB). Clear after first boot if desired.
ADMIN_EMAIL=admin@chid.ru
ADMIN_PASSWORD=change-me-strong-admin-password
ADMIN_FULL_NAME=Администратор CHID

# --- CRM build-time (baked into static assets) ---
VITE_PUBLIC_SITE_URL=https://chid.ru
VITE_CHID_PHONE=+7 (495) 000-00-00
VITE_CHID_PHONE_HREF=+74950000000
VITE_CHID_EMAIL=info@chid.ru

# --- Images (CI/CD) ---
# local build tags images as :local; CD sets IMAGE_TAG to git sha (12 chars)
IMAGE_TAG=local

# --- Proxy ---
HTTP_PORT=80
HTTPS_PORT=443
SSL_CERTS_DIR=./certs

# For local smoke (--profile local) also set:
# HTTP_PORT=8088
# CORS_ALLOWED_ORIGINS=http://localhost:8088,http://crm.localhost:8088
